<Window x:Class="LiveTranscript.MainWindow"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:conv="clr-namespace:LiveTranscript.Converters"
         Title="Live Transcript"
         Width="520" Height="680"
         MinWidth="400" MinHeight="350"
         WindowStyle="None"
         AllowsTransparency="True"
         Background="Transparent"
         Topmost="True"
         ResizeMode="CanResizeWithGrip"
         ShowInTaskbar="False">

    <Window.Resources>
        <conv:SpeakerToColorConverter x:Key="SpeakerColorConv"/>
        <conv:FinalToOpacityConverter x:Key="FinalOpacityConv"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisConv"/>
        <SolidColorBrush x:Key="TranscriptCardBackgroundBrush" Color="#2BFFFFFF"/>
        <SolidColorBrush x:Key="QaCardBackgroundBrush" Color="#24FFFFFF"/>
        <SolidColorBrush x:Key="QaAnswerBackgroundBrush" Color="#1FFFFFFF"/>
        <SolidColorBrush x:Key="FollowUpCardBackgroundBrush" Color="#22FFFFFF"/>
        <SolidColorBrush x:Key="FollowUpAnswerBackgroundBrush" Color="#18FFFFFF"/>
    </Window.Resources>

    <Border x:Name="RootShell"
            CornerRadius="16"
            Background="#B30A1423"
            BorderBrush="#66BFD6EF"
            BorderThickness="1"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="36" ShadowDepth="0" Opacity="0.55" Color="#FF05080E"/>
        </Border.Effect>

        <Grid x:Name="RootGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Title bar -->
                <RowDefinition Height="Auto"/>  <!-- Controls -->
                <RowDefinition Height="*"/>     <!-- Tab content -->
                <RowDefinition Height="Auto"/>  <!-- Status bar -->
            </Grid.RowDefinitions>

            <!-- ═══ Title Bar ═══ -->
            <Border x:Name="TitleBarBorder" Grid.Row="0" Background="#8C102238" CornerRadius="16,16,0,0"
                    Padding="16,10" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="RecordingDot" Width="10" Height="10"
                                  Fill="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                        <TextBlock Text="LIVE TRANSCRIPT" FontSize="13" FontWeight="SemiBold"
                                    Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI"
                                    VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="⚙" Style="{StaticResource OverlayButton}"
                                Padding="8,4" FontSize="11" Click="Settings_Click" Margin="0,0,4,0"
                                ToolTip="Settings"/>
                        <Button Content="─" Style="{StaticResource OverlayButton}"
                                Padding="8,4" FontSize="11" Click="Minimize_Click" Margin="0,0,4,0"/>
                        <Button x:Name="PinButton" Content="📌" Style="{StaticResource OverlayButton}"
                                Padding="8,4" FontSize="11" Click="Pin_Click" Margin="0,0,4,0"
                                ToolTip="Toggle always on top"/>
                        <Button Content="✕" Style="{StaticResource OverlayButton}"
                                Padding="8,4" FontSize="11" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ Controls Bar ═══ -->
            <Border x:Name="ControlsBarBorder" Grid.Row="1" Background="#66162A42" Padding="12,10"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="190"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Transcription Provider" FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="2,0,0,3"/>
                        <ComboBox x:Name="ProviderSelector"
                                  SelectedIndex="1" Margin="0,0,6,0"
                                  ToolTip="Transcription provider">
                            <ComboBoxItem Content="AssemblyAI"/>
                            <ComboBoxItem Content="Deepgram"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Audio Source" FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="2,0,0,3"/>
                        <ComboBox x:Name="SourceSelector"
                                  SelectedIndex="2" Margin="0,0,8,0">
                            <ComboBoxItem Content="🎤 Mic Only"/>
                            <ComboBoxItem Content="🔊 Speaker Only"/>
                            <ComboBoxItem Content="🎤+🔊 Both"/>
                        </ComboBox>
                    </StackPanel>

                    <Button Grid.Column="2" Content="🗑️" Style="{StaticResource OverlayButton}"
                            Padding="8,6" FontSize="12" Click="Clear_Click"
                            ToolTip="Clear transcript" Margin="0,0,6,0"/>

                    <Button x:Name="StartStopButton" Grid.Column="3"
                            Content="▶  Start" Click="StartStop_Click"
                            FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI"
                            Padding="18,8" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource OverlayButton}">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FF00D2D3" Offset="0"/>
                                            <GradientStop Color="#FF0099CC" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="#FF0D1117"/>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- ═══ Split View ═══ -->
            <Grid x:Name="SplitViewGrid" Grid.Row="2" Background="Transparent" Margin="6,4,6,6"
                  MouseLeftButtonDown="HudContainer_MouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="0.9*"/>
                </Grid.ColumnDefinitions>

                <!-- ── Transcript Panel (Left) ── -->
                <Border Grid.Column="0" Margin="2,2,2,2"
                        Background="#141F3048" BorderBrush="#40A6BDD8" BorderThickness="1" CornerRadius="12">
                    <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid x:Name="TranscriptHeaderRow" Margin="12,8,12,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="📝 Transcript" FontSize="14" FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <Button Grid.Column="1" Content="Copy All" Style="{StaticResource OverlayButton}"
                                Padding="10,4" FontSize="11" Margin="8,0,0,0"
                                Click="CopyTranscriptAll_Click" ToolTip="Copy full transcript"/>
                    </Grid>
                    <Border x:Name="TranscriptPanelBackdrop" Grid.Row="1" Margin="8,0,8,8"
                            Background="#1AFFFFFF" CornerRadius="12"
                            BorderBrush="#33D7EEFF" BorderThickness="1">
                        <ScrollViewer x:Name="TranscriptScroller"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="12,0,12,8">
                            <ItemsControl x:Name="TranscriptList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,3" Padding="10,8"
                                                Background="{StaticResource TranscriptCardBackgroundBrush}" CornerRadius="10"
                                                BorderBrush="#26D7EEFF" BorderThickness="1"
                                                Opacity="{Binding IsFinal, Converter={StaticResource FinalOpacityConv}}">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                                             Fill="{Binding Speaker, Converter={StaticResource SpeakerColorConv}}"/>
                                                    <TextBlock Text="{Binding Speaker}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{Binding Speaker, Converter={StaticResource SpeakerColorConv}}"
                                                               FontFamily="Segoe UI"/>
                                                    <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                                                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                                               Margin="10,0,0,0" VerticalAlignment="Center"
                                                               FontFamily="Segoe UI"/>
                                                </StackPanel>
                                                <TextBox Text="{Binding Text}"
                                                         IsReadOnly="True"
                                                         BorderThickness="0"
                                                         Background="Transparent"
                                                         TextWrapping="Wrap"
                                                         FontSize="14"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         FontFamily="Segoe UI"
                                                         Padding="0"
                                                         HorizontalScrollBarVisibility="Disabled"
                                                         VerticalScrollBarVisibility="Disabled"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
                </Border>

                <!-- Separator -->
                <Rectangle x:Name="SplitSeparator" Grid.Column="1" Fill="#2AA6BDD8" Width="1"
                           HorizontalAlignment="Center" VerticalAlignment="Stretch" Margin="0,10"/>

                <!-- ── AI Assistant Panel (Right) ── -->
                <Border Grid.Column="2" Margin="2,2,2,2"
                        Background="#141F3048" BorderBrush="#40A6BDD8" BorderThickness="1" CornerRadius="12">
                <Grid x:Name="AiPanelGrid">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Header -->
                        <RowDefinition Height="Auto"/>  <!-- Model picker controls -->
                        <RowDefinition Height="Auto"/>   <!-- Model list / indicator -->
                        <RowDefinition Height="Auto"/>  <!-- Extract button -->
                        <RowDefinition Height="*"/>     <!-- Results -->
                    </Grid.RowDefinitions>

                    <Grid x:Name="AiHeaderRow" Margin="12,8,12,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="🤖 AI Assistant" FontSize="14" FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <Button Grid.Column="1" Content="Copy All" Style="{StaticResource OverlayButton}"
                                Padding="10,4" FontSize="11" Margin="8,0,0,0"
                                Click="CopyQaAll_Click" ToolTip="Copy all questions and answers"/>
                    </Grid>


                    <!-- Model filter bar -->
                    <StackPanel x:Name="ModelFilterBar" Grid.Row="1" Orientation="Horizontal" Margin="12,6,12,4">
                        <TextBox x:Name="ModelSearchBox" Width="220"
                                 TextChanged="ModelSearch_Changed"
                                 Tag="Search models…"/>
                        <CheckBox x:Name="FreeOnlyCheck" Content="Free only"
                                  Margin="10,0,0,0" VerticalAlignment="Center"
                                  Checked="FreeOnly_Changed" Unchecked="FreeOnly_Changed"/>
                        <Button Content="↻" Style="{StaticResource OverlayButton}"
                                Padding="8,4" FontSize="11" Margin="8,0,0,0"
                                Click="RefreshModels_Click" ToolTip="Refresh model list"/>
                    </StackPanel>

                    <!-- Claude model indicator -->
                    <Border x:Name="ClaudeModelIndicator" Grid.Row="2" Margin="12,4"
                            Background="#2EFFFFFF" CornerRadius="10" Padding="12,8"
                            BorderBrush="#33D7EEFF" BorderThickness="1"
                            VerticalAlignment="Top"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🧠" FontSize="16" VerticalAlignment="Center"/>
                            <StackPanel Margin="8,0,0,0">
                                <TextBlock Text="Claude 4.5 Haiku" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Anthropic's fast, efficient model" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Model list -->
                    <ListView x:Name="ModelListView" Grid.Row="2" Margin="12,0,12,4"
                              Height="160"
                              SelectionChanged="ModelList_SelectionChanged">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Model" Width="160"
                                                    DisplayMemberBinding="{Binding Name}"/>
                                    <GridViewColumn Header="Params" Width="50"
                                                    DisplayMemberBinding="{Binding ParameterCount}"/>
                                    <GridViewColumn Header="Context" Width="60"
                                                    DisplayMemberBinding="{Binding ContextDisplay}"/>
                                    <GridViewColumn Header="Price" Width="80"
                                                    DisplayMemberBinding="{Binding PriceDisplay}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>

                    <!-- Extract button row -->
                    <WrapPanel x:Name="ExtractControlsRow" Grid.Row="3" Margin="12,6,12,4">
                            <Button x:Name="ExtractButton" Click="Extract_Click"
                                    Content="🧠  Extract Questions" Cursor="Hand"
                                    FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI"
                                    Padding="14,8" IsEnabled="False">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource OverlayButton}">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#FF9B59B6" Offset="0"/>
                                                    <GradientStop Color="#FF8E44AD" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button x:Name="AutoExtractButton" Click="AutoExtract_Click"
                                    Content="⚡ Auto Stream" Cursor="Hand"
                                    FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"
                                    Padding="10,8" Margin="8,0,0,0" IsEnabled="False"
                                    ToolTip="Auto-stream questions and answers as transcript grows">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource OverlayButton}">
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button x:Name="ToggleAllButton" Content="👁 Show All" Style="{StaticResource OverlayButton}"
                                    Padding="10,8" FontSize="11" Margin="8,0,0,0"
                                    Click="ToggleAll_Click" ToolTip="Show/hide all answers"/>
                            <Button Content="Clear AI History" Style="{StaticResource OverlayButton}"
                                    Padding="10,8" FontSize="11" Margin="8,0,0,0"
                                    Click="ClearAiHistory_Click" ToolTip="Reset answered questions list"/>
                        </WrapPanel>

                    <!-- Q&A Cards -->
                    <Border x:Name="QaPanelBackdrop" Grid.Row="4" Margin="12,4,12,8"
                            Background="#1AFFFFFF" CornerRadius="12"
                            BorderBrush="#33D7EEFF" BorderThickness="1">
                        <ScrollViewer x:Name="QaScroller" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8,0,8,8">
                                <!-- Status text -->
                                <TextBlock x:Name="AiStatusText"
                                           Text="Select a model and click Extract Questions"
                                           FontSize="12" FontStyle="Italic"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,4,0,8"/>

                                <!-- Q&A list -->
                                <ItemsControl x:Name="QaList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,3" Padding="12,10"
                                                    Background="{StaticResource QaCardBackgroundBrush}" CornerRadius="10"
                                                    BorderBrush="#26D7EEFF" BorderThickness="1">
                                                <StackPanel>
                                                    <!-- Question header row -->
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Q number badge -->
                                                        <Border Grid.Column="0" Background="#FF9B59B6"
                                                                CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                                                                VerticalAlignment="Top">
                                                            <TextBlock Text="{Binding DisplayBadge}"
                                                                       FontSize="11" FontWeight="Bold"
                                                                       Foreground="White" FontFamily="Segoe UI"/>
                                                        </Border>

                                                        <!-- Question text -->
                                                        <TextBox Grid.Column="1" Text="{Binding Question}"
                                                                 IsReadOnly="True"
                                                                 BorderThickness="0"
                                                                 Background="Transparent"
                                                                 TextWrapping="Wrap"
                                                                 FontSize="13" FontWeight="SemiBold"
                                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                                 FontFamily="Segoe UI"
                                                                 Padding="0"
                                                                 VerticalAlignment="Center"
                                                                 HorizontalScrollBarVisibility="Disabled"
                                                                 VerticalScrollBarVisibility="Disabled"/>

                                                        <!-- Expand/collapse toggle -->
                                                        <Button Grid.Column="2" Style="{StaticResource OverlayButton}"
                                                                Padding="6,4" FontSize="10" Margin="6,0,0,0"
                                                                Click="ToggleAnswer_Click" Tag="{Binding}"
                                                                VerticalAlignment="Top">
                                                            <Button.Content>
                                                                <TextBlock Text="{Binding IsExpanded,
                                                                    FallbackValue='▼'}">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="▶ Show"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                                    <Setter Property="Text" Value="▼ Hide"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Button.Content>
                                                        </Button>
                                                    </Grid>

                                                    <!-- Answer section (collapsible) -->
                                                    <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisConv}}"
                                                                Margin="0,8,0,0">
                                                        <!-- Paragraph answer -->
                                                        <Border Background="{StaticResource QaAnswerBackgroundBrush}" CornerRadius="8"
                                                                BorderBrush="#20D7EEFF" BorderThickness="1"
                                                                Padding="10,8" Margin="0,0,0,6">
                                                            <TextBox Text="{Binding ParagraphAnswer, UpdateSourceTrigger=PropertyChanged}"
                                                                     IsReadOnly="True"
                                                                     BorderThickness="0"
                                                                     Background="Transparent"
                                                                     TextWrapping="Wrap"
                                                                     FontSize="12.5"
                                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                                     FontFamily="Segoe UI"
                                                                     Padding="0"
                                                                     HorizontalScrollBarVisibility="Disabled"
                                                                     VerticalScrollBarVisibility="Disabled"/>
                                                        </Border>

                                                        <!-- Key points -->
                                                        <TextBox Text="{Binding KeyPoints, UpdateSourceTrigger=PropertyChanged}"
                                                                 IsReadOnly="True"
                                                                 BorderThickness="0"
                                                                 Background="Transparent"
                                                                 TextWrapping="Wrap"
                                                                 FontSize="12"
                                                                 Foreground="{StaticResource TextSecondaryBrush}"
                                                                 FontFamily="Segoe UI"
                                                                 Margin="4,0,0,0"
                                                                 Padding="0"
                                                                 HorizontalScrollBarVisibility="Disabled"
                                                         VerticalScrollBarVisibility="Disabled"/>
                                                    </StackPanel>

                                                    <ItemsControl ItemsSource="{Binding FollowUps}" Margin="20,8,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Margin="0,4,0,0" Padding="10,8"
                                                                        Background="{StaticResource FollowUpCardBackgroundBrush}" CornerRadius="8"
                                                                        BorderBrush="#22D7EEFF" BorderThickness="1">
                                                                    <StackPanel>
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                            </Grid.ColumnDefinitions>

                                                                            <Border Grid.Column="0" Background="#FF4FA3D1"
                                                                                    CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                                                                                    VerticalAlignment="Top">
                                                                                <TextBlock Text="{Binding DisplayBadge}"
                                                                                           FontSize="10.5" FontWeight="Bold"
                                                                                           Foreground="White" FontFamily="Segoe UI"/>
                                                                            </Border>

                                                                            <TextBox Grid.Column="1" Text="{Binding Question}"
                                                                                     IsReadOnly="True"
                                                                                     BorderThickness="0"
                                                                                     Background="Transparent"
                                                                                     TextWrapping="Wrap"
                                                                                     FontSize="12.5" FontWeight="SemiBold"
                                                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                                                     FontFamily="Segoe UI"
                                                                                     Padding="0"
                                                                                     VerticalAlignment="Center"
                                                                                     HorizontalScrollBarVisibility="Disabled"
                                                                                     VerticalScrollBarVisibility="Disabled"/>

                                                                            <Button Grid.Column="2" Style="{StaticResource OverlayButton}"
                                                                                    Padding="6,4" FontSize="10" Margin="6,0,0,0"
                                                                                    Click="ToggleAnswer_Click" Tag="{Binding}"
                                                                                    VerticalAlignment="Top">
                                                                                <Button.Content>
                                                                                    <TextBlock Text="{Binding IsExpanded,
                                                                                        FallbackValue='▼'}">
                                                                                        <TextBlock.Style>
                                                                                            <Style TargetType="TextBlock">
                                                                                                <Setter Property="Text" Value="▶ Show"/>
                                                                                                <Style.Triggers>
                                                                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                                                        <Setter Property="Text" Value="▼ Hide"/>
                                                                                                    </DataTrigger>
                                                                                                </Style.Triggers>
                                                                                            </Style>
                                                                                        </TextBlock.Style>
                                                                                    </TextBlock>
                                                                                </Button.Content>
                                                                            </Button>
                                                                        </Grid>

                                                                        <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisConv}}"
                                                                                    Margin="0,8,0,0">
                                                                            <Border Background="{StaticResource FollowUpAnswerBackgroundBrush}" CornerRadius="7"
                                                                                    BorderBrush="#1FD7EEFF" BorderThickness="1"
                                                                                    Padding="8,6" Margin="0,0,0,5">
                                                                                <TextBox Text="{Binding ParagraphAnswer, UpdateSourceTrigger=PropertyChanged}"
                                                                                         IsReadOnly="True"
                                                                                         BorderThickness="0"
                                                                                         Background="Transparent"
                                                                                         TextWrapping="Wrap"
                                                                                         FontSize="12"
                                                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                                                         FontFamily="Segoe UI"
                                                                                         Padding="0"
                                                                                         HorizontalScrollBarVisibility="Disabled"
                                                                                         VerticalScrollBarVisibility="Disabled"/>
                                                                            </Border>

                                                                            <TextBox Text="{Binding KeyPoints, UpdateSourceTrigger=PropertyChanged}"
                                                                                     IsReadOnly="True"
                                                                                     BorderThickness="0"
                                                                                     Background="Transparent"
                                                                                     TextWrapping="Wrap"
                                                                                     FontSize="11.5"
                                                                                     Foreground="{StaticResource TextSecondaryBrush}"
                                                                                     FontFamily="Segoe UI"
                                                                                     Margin="2,0,0,0"
                                                                                     Padding="0"
                                                                                     HorizontalScrollBarVisibility="Disabled"
                                                                                     VerticalScrollBarVisibility="Disabled"/>
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
                </Border>
            </Grid>

            <!-- HUD draggable modules -->
            <Canvas x:Name="HudCanvas"
                    Grid.Row="2" Grid.RowSpan="2"
                    Visibility="Collapsed"
                    Background="Transparent"
                    MouseLeftButtonDown="HudContainer_MouseDown">
                <Border x:Name="HudTranscriptModule"
                        Width="420" Height="360"
                        MinWidth="260" MinHeight="180"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Background="Transparent"
                                Padding="0,0,0,6"
                                MouseLeftButtonDown="HudModuleHeader_MouseLeftButtonDown"
                                MouseMove="HudModuleHeader_MouseMove"
                                MouseLeftButtonUp="HudModuleHeader_MouseLeftButtonUp"
                                Cursor="SizeAll"
                                Tag="{Binding ElementName=HudTranscriptModule}">
                            <Grid MinHeight="30">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border HorizontalAlignment="Left"
                                        Background="#CC000000"
                                        CornerRadius="7"
                                        Padding="9,5"
                                        ToolTip="Drag this HUD box">
                                    <TextBlock Text="📝 Transcript"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                </Border>
                                <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <Button Content="{Binding ElementName=StartStopButton, Path=Content}"
                                            Click="StartStop_Click"
                                            Style="{StaticResource OverlayButton}"
                                            Padding="9,4"
                                            FontSize="10.5"
                                            Margin="6,0,0,0"
                                            ToolTip="Start or stop transcription"/>
                                    <Button Content="🗑"
                                            Click="Clear_Click"
                                            Style="{StaticResource OverlayButton}"
                                            Padding="8,4"
                                            FontSize="10.5"
                                            Margin="6,0,0,0"
                                            ToolTip="Clear transcript"/>
                                    <Button Content="Copy"
                                            Click="CopyTranscriptAll_Click"
                                            Style="{StaticResource OverlayButton}"
                                            Padding="8,4"
                                            FontSize="10.5"
                                            Margin="6,0,0,0"
                                            ToolTip="Copy full transcript"/>
                                    <Button Content="{Binding ElementName=PinButton, Path=Content}"
                                            Click="Pin_Click"
                                            Style="{StaticResource OverlayButton}"
                                            Padding="8,4"
                                            FontSize="10.5"
                                            Margin="6,0,0,0"
                                            ToolTip="Toggle always on top"/>
                                    <Button Content="─"
                                            Click="Minimize_Click"
                                            Style="{StaticResource OverlayButton}"
                                            Padding="8,4"
                                            FontSize="10.5"
                                            Margin="6,0,0,0"
                                            ToolTip="Hide overlay"/>
                                    <Button Content="✕"
                                            Click="Close_Click"
                                            Style="{StaticResource OverlayButton}"
                                            Padding="8,4"
                                            FontSize="10.5"
                                            Margin="6,0,0,0"
                                            ToolTip="Close"/>
                                </WrapPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Row="1"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0">
                            <ScrollViewer x:Name="HudTranscriptScroller"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Background="Transparent"
                                          Padding="0">
                                <ItemsControl x:Name="HudTranscriptList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,2" Padding="8,6"
                                                    Background="{StaticResource TranscriptCardBackgroundBrush}"
                                                    CornerRadius="6"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="0">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Speaker}"
                                                               FontSize="10.5" FontWeight="SemiBold"
                                                               Foreground="{Binding Speaker, Converter={StaticResource SpeakerColorConv}}"/>
                                                    <TextBlock Text="{Binding Text}"
                                                               FontSize="13"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                        <Border Grid.RowSpan="2"
                                Width="24" Height="24"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Background="#66000000"
                                CornerRadius="5"
                                Cursor="SizeNWSE"
                                ToolTip="Resize this HUD box"
                                MouseLeftButtonDown="HudModuleResize_MouseLeftButtonDown"
                                MouseMove="HudModuleResize_MouseMove"
                                MouseLeftButtonUp="HudModuleResize_MouseLeftButtonUp"
                                Tag="{Binding ElementName=HudTranscriptModule}">
                            <TextBlock Text="↘"
                                       FontSize="15"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <Border x:Name="HudAnswersModule"
                        Width="420" Height="360"
                        MinWidth="260" MinHeight="180"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Background="Transparent"
                                Padding="0,0,0,6"
                                MouseLeftButtonDown="HudModuleHeader_MouseLeftButtonDown"
                                MouseMove="HudModuleHeader_MouseMove"
                                MouseLeftButtonUp="HudModuleHeader_MouseLeftButtonUp"
                                Cursor="SizeAll"
                                Tag="{Binding ElementName=HudAnswersModule}">
                            <Grid MinHeight="30">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border HorizontalAlignment="Left"
                                        Background="#CC000000"
                                        CornerRadius="7"
                                        Padding="9,5"
                                        ToolTip="Drag this HUD box">
                                    <TextBlock Text="🤖 Answers"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                </Border>
                                <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <Button Click="Extract_Click"
                                            Content="🧠 Extract"
                                            Style="{StaticResource OverlayButton}"
                                            Padding="9,4"
                                            FontSize="10.5"
                                            Margin="6,0,0,0"
                                            IsEnabled="{Binding ElementName=ExtractButton, Path=IsEnabled}"
                                            ToolTip="Extract questions and generate answers"/>
                                    <Button Click="AutoExtract_Click"
                                            Content="{Binding ElementName=AutoExtractButton, Path=Content}"
                                            Style="{StaticResource OverlayButton}"
                                            Padding="8,4"
                                            FontSize="10.5"
                                            Margin="6,0,0,0"
                                            IsEnabled="{Binding ElementName=AutoExtractButton, Path=IsEnabled}"
                                            Foreground="{Binding ElementName=AutoExtractButton, Path=Foreground}"
                                            ToolTip="Auto-stream questions and answers as transcript grows"/>
                                    <Button Click="ToggleAll_Click"
                                            Content="{Binding ElementName=ToggleAllButton, Path=Content}"
                                            Style="{StaticResource OverlayButton}"
                                            Padding="8,4"
                                            FontSize="10.5"
                                            Margin="6,0,0,0"
                                            ToolTip="Show/hide all answers"/>
                                    <Button Content="Clear AI"
                                            Click="ClearAiHistory_Click"
                                            Style="{StaticResource OverlayButton}"
                                            Padding="8,4"
                                            FontSize="10.5"
                                            Margin="6,0,0,0"
                                            ToolTip="Clear AI answers and history"/>
                                    <Button Content="Copy"
                                            Click="CopyQaAll_Click"
                                            Style="{StaticResource OverlayButton}"
                                            Padding="8,4"
                                            FontSize="10.5"
                                            Margin="6,0,0,0"
                                            ToolTip="Copy all questions and answers"/>
                                </WrapPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Row="1"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0">
                            <ScrollViewer x:Name="HudQaScroller" VerticalScrollBarVisibility="Auto" Background="Transparent" Padding="0">
                                <StackPanel>
                                    <Border Background="#CC000000"
                                            CornerRadius="6"
                                            Padding="8,6"
                                            Margin="0,0,0,6">
                                        <TextBlock Text="{Binding ElementName=AiStatusText, Path=Text}"
                                                   FontSize="11.5" FontStyle="Italic"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"/>
                                    </Border>
                                    <ItemsControl x:Name="HudQaList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,3" Padding="10,8"
                                                        Background="{StaticResource QaCardBackgroundBrush}"
                                                        CornerRadius="6"
                                                        BorderBrush="Transparent"
                                                        BorderThickness="0">
                                                    <StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock Text="{Binding DisplayBadge}" FontSize="10.5" FontWeight="Bold"
                                                                           Foreground="#FFD8A8FF"/>
                                                                <TextBlock Text="{Binding Question}" Margin="0,4,0,4"
                                                                           FontSize="12.5" FontWeight="SemiBold"
                                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                                           TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                            <Button Grid.Column="1"
                                                                    Style="{StaticResource OverlayButton}"
                                                                    Padding="6,3"
                                                                    FontSize="10"
                                                                    Margin="8,0,0,0"
                                                                    VerticalAlignment="Top"
                                                                    Click="ToggleAnswer_Click"
                                                                    Tag="{Binding}">
                                                                <Button.Content>
                                                                    <TextBlock>
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Text" Value="Show"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                                        <Setter Property="Text" Value="Hide"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Button.Content>
                                                            </Button>
                                                        </Grid>
                                                        <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisConv}}">
                                                            <TextBlock Text="{Binding ParagraphAnswer}"
                                                                       FontSize="12"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding KeyPoints}"
                                                                       FontSize="11.5"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,5,0,0"/>
                                                        </StackPanel>
                                                        <ItemsControl ItemsSource="{Binding FollowUps}"
                                                                      Margin="14,6,0,0">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Margin="0,3,0,0"
                                                                            Padding="8,6"
                                                                            Background="{StaticResource FollowUpCardBackgroundBrush}"
                                                                            CornerRadius="6"
                                                                            BorderBrush="Transparent"
                                                                            BorderThickness="0">
                                                                        <StackPanel>
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="*"/>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <StackPanel Grid.Column="0">
                                                                                    <TextBlock Text="{Binding DisplayBadge}"
                                                                                               FontSize="10"
                                                                                               FontWeight="Bold"
                                                                                               Foreground="#FF9BD7FF"/>
                                                                                    <TextBlock Text="{Binding Question}"
                                                                                               Margin="0,3,0,3"
                                                                                               FontSize="12"
                                                                                               FontWeight="SemiBold"
                                                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                                                               TextWrapping="Wrap"/>
                                                                                </StackPanel>
                                                                                <Button Grid.Column="1"
                                                                                        Style="{StaticResource OverlayButton}"
                                                                                        Padding="6,3"
                                                                                        FontSize="10"
                                                                                        Margin="8,0,0,0"
                                                                                        VerticalAlignment="Top"
                                                                                        Click="ToggleAnswer_Click"
                                                                                        Tag="{Binding}">
                                                                                    <Button.Content>
                                                                                        <TextBlock>
                                                                                            <TextBlock.Style>
                                                                                                <Style TargetType="TextBlock">
                                                                                                    <Setter Property="Text" Value="Show"/>
                                                                                                    <Style.Triggers>
                                                                                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                                                            <Setter Property="Text" Value="Hide"/>
                                                                                                        </DataTrigger>
                                                                                                    </Style.Triggers>
                                                                                                </Style>
                                                                                            </TextBlock.Style>
                                                                                        </TextBlock>
                                                                                    </Button.Content>
                                                                                </Button>
                                                                            </Grid>
                                                                            <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisConv}}">
                                                                                <TextBlock Text="{Binding ParagraphAnswer}"
                                                                                           FontSize="11.5"
                                                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                                                           TextWrapping="Wrap"/>
                                                                                <TextBlock Text="{Binding KeyPoints}"
                                                                                           FontSize="11"
                                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                                           TextWrapping="Wrap"
                                                                                           Margin="0,5,0,0"/>
                                                                            </StackPanel>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                        <Border Grid.RowSpan="2"
                                Width="24" Height="24"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Background="#66000000"
                                CornerRadius="5"
                                Cursor="SizeNWSE"
                                ToolTip="Resize this HUD box"
                                MouseLeftButtonDown="HudModuleResize_MouseLeftButtonDown"
                                MouseMove="HudModuleResize_MouseMove"
                                MouseLeftButtonUp="HudModuleResize_MouseLeftButtonUp"
                                Tag="{Binding ElementName=HudAnswersModule}">
                            <TextBlock Text="↘"
                                       FontSize="15"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
            </Canvas>

            <Button x:Name="HudExtractButton"
                    Grid.Row="2" Grid.RowSpan="2"
                    Panel.ZIndex="50"
                    Visibility="Collapsed"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,18,0"
                    Click="Extract_Click"
                    Content="🧠 Extract + Answer"
                    FontSize="12" FontWeight="SemiBold"
                    Padding="14,10"
                    IsEnabled="False"
                    ToolTip="Extract interview questions and generate answers">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource OverlayButton}">
                        <Setter Property="Background">
                            <Setter.Value>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF9B59B6" Offset="0"/>
                                    <GradientStop Color="#FF8E44AD" Offset="1"/>
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Foreground" Value="White"/>
                    </Style>
                </Button.Style>
            </Button>

            <!-- ═══ Settings Flyout ═══ -->
            <Border x:Name="SettingsPanel" Grid.Row="2" Grid.RowSpan="2"
                    Background="#D2111A26" Visibility="Collapsed"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="⚙ Settings" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                        <!-- AI Provider -->
                        <TextBlock Text="AI Provider" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="SettingsAiProvider" Margin="0,0,0,12"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="OpenRouter"/>
                            <ComboBoxItem Content="Claude (Anthropic)"/>
                            <ComboBoxItem Content="LM Studio (Local)"/>
                        </ComboBox>

                        <!-- OpenRouter API Key -->
                        <TextBlock Text="OpenRouter API Key" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="SettingsApiKey" Margin="0,0,0,12"/>

                        <!-- Claude API Key -->
                        <TextBlock Text="Claude API Key" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="SettingsClaudeApiKey" Margin="0,0,0,12"/>

                        <!-- LM Studio -->
                        <TextBlock Text="LM Studio Base URL" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="SettingsLmStudioBaseUrl" Margin="0,0,0,12"/>
                        <TextBlock Text="LM Studio API Key (Optional)" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="SettingsLmStudioApiKey" Margin="0,0,0,12"/>

                        <!-- AssemblyAI API Key -->
                        <TextBlock Text="AssemblyAI API Key (Required for Speaker Mode)" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="SettingsAssemblyKey" Margin="0,0,0,12"/>

                        <!-- Deepgram API Key -->
                        <TextBlock Text="Deepgram API Key (Optional)" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="SettingsDeepgramKey" Margin="0,0,0,12"/>

                        <!-- Job Description -->
                        <TextBlock Text="Job Description" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="SettingsJobDesc" AcceptsReturn="True" TextWrapping="Wrap"
                                 Height="120" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12"/>

                        <!-- Resume -->
                        <TextBlock Text="Resume / Background" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="SettingsResume" AcceptsReturn="True" TextWrapping="Wrap"
                                 Height="120" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16"/>

                        <!-- Save / Close -->
                        <StackPanel Orientation="Horizontal">
                            <Button Content="💾  Save" Click="SaveSettings_Click"
                                    FontSize="12" Padding="14,8" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource OverlayButton}">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#FF56D364" Offset="0"/>
                                                    <GradientStop Color="#FF2EA043" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="#FF0D1117"/>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="Close" Style="{StaticResource OverlayButton}"
                                    Padding="14,8" FontSize="12" Margin="8,0,0,0"
                                    Click="CloseSettings_Click"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ═══ Status Bar ═══ -->
            <Border x:Name="StatusBarBorder" Grid.Row="3" Background="#4D1A2636" CornerRadius="0,0,16,16"
                    Padding="14,8"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="StatusText" Grid.Column="0"
                               Text="Ready — Press Start to begin"
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="Segoe UI" VerticalAlignment="Center"/>

                    <TextBlock x:Name="EntryCount" Grid.Column="1"
                               Text="0 entries"
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
